---
import MemberPreview from '@/components/MemberPreview.astro'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  members: (CollectionEntry<'members'> | CollectionEntry<'prev_members'>)[]
}
const { members } = Astro.props
---

<div class="grid grid-cols-1 gap-8 md:grid-cols-2">
  {members.map((member) => <MemberPreview {member} />)}
</div>
